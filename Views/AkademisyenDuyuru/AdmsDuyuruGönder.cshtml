@model AkademikBilgiSistemi.Models.Tbl_Duyurular
@{
    ViewBag.Title = "AdmsDuyuruGönder";
    Layout = "~/Views/Shared/_LayoutAkademisyen.cshtml";
}

<!DOCTYPE html>
<html>
<head>
    <style>
        .sayfa {
            width: 100%;
            margin: 30px 30px 30px 0px;
        }
    </style>
</head>
<body>
    <div id="content">
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="container-fluid">
                <button type="button" id="sidebarCollapse" class="btn btn-info" style="background: #9b8080; border: 0px">
                    <i class="fas fa-align-left"></i>
                </button>
                <h3 style="position:absolute; right:90px; top:3px"> KAYSERİ ÜNİVERSİTESİ</h3>
                <img src="~/login-form-v1/Login_v1/images/uniLogo.png" style="height:60px; position:absolute; right:10px; top:2px" />
            </div>
        </nav>
        <div class="container-fluid">
            <nav class="navbar navbar-expand-lg navbar-light bg-light">
                <div class="container-fluid">
                    <h2>DUYURU YAYINLA</h2>
                    <br />
                    <form method="post">
                        <div class="container-fluid">
                            <nav class="navbar navbar-expand-lg navbar-light bg-light" style=" border-block:outset; border-block-color:#808080">
                                <div class="sayfa">
                                    <h4>Duyuruyu Gönderen</h4>
                                    <input type="text" value="@Session["OgretmenAdi"]  @Session["OgretmenSoyadi"]" readonly name="DuyuruBaslik" placeholder="Başlık" style="position:relative; width:100%; border:groove; border-radius:5px 5px 5px 5px" />
                                </div>
                                <div class="sayfa">
                                    <h4>Duyuru Başlığı</h4>
                                    <input type="text" name="DuyuruBaslik" placeholder="Başlık" style="position:relative; width:100%; border:groove; border-radius:5px 5px 5px 5px" />
                                </div>
                                <div class="sayfa">
                                    <h4>Duyuru İçeriği</h4>
                                    <textarea placeholder="İçerik" required name="Duyuruİçerik" style="position:relative; width:100%; height:130px; border:groove; border-radius:5px 5px 5px 5px"></textarea>
                                </div>

                                <button type="submit" style="background-color: #777272; border:none; padding:10px 20px; border-radius:6px 6px 6px 6px; font-size:20px; color:#ffffff">
                                    Yayınla
                                </button>
                            </nav>

                        </div>

                    </form>

                </div>
            </nav>
        </div>
    </div>
</body>
</html>