
@model AkademikBilgiSistemi.Models.Tbl_Ogretmenler
@{
    Layout = null;
}


<!DOCTYPE html>
<html lang="en">
<head>
    <title>Öğrenci Giriş</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <!--===============================================================================================-->
    <link href="~/login-form-v1/Login_v1/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <!--===============================================================================================-->
    <link href="~/login-form-v1/Login_v1/fonts/font-awesome-4.7.0/css/font-awesome.min.css" rel="stylesheet" />
    <!--===============================================================================================-->
    <link href="~/login-form-v1/Login_v1/vendor/animate/animate.css" rel="stylesheet" />
    <!--===============================================================================================-->
    <link href="~/login-form-v1/Login_v1/vendor/css-hamburgers/hamburgers.min.css" rel="stylesheet" />
    <!--===============================================================================================-->
    <link href="~/login-form-v1/Login_v1/vendor/select2/select2.min.css" rel="stylesheet" />
    <!--===============================================================================================-->
    <link href="~/login-form-v1/Login_v1/css/util.css" rel="stylesheet" />
    <link href="~/login-form-v1/Login_v1/css/main.css" rel="stylesheet" />
    <!--===============================================================================================-->
    <style>
        image{
            height:225px;
            width:225px
        }
    </style>
</head>
<body>

    <div class="limiter">
        <div class="container-login100">
            <div class="wrap-login100">

                <div class="login100-pic js-tilt" data-tilt>
                    <a href="~/Login/OgrLogin">
                        <img src="~/login-form-v1/Login_v1/images/images.png" />
                        <br />
                        <br />
                        <h2>ÖĞRENCİ GİRİŞİ</h2>
                    </a>
                </div>
                <div class="login100-pic js-tilt" data-tilt>
                    <a href="~/Login/AdmsLogin" style="text-align:left">
                        <img src="~/login-form-v1/Login_v1/images/image2.png" style="height:220px" />
                        <br />
                        <br />
                        <h2>ÖĞRETMEN GİRİŞİ</h2>

                    </a>
                </div>
            </div>
        </div>
    </div>




    <!--===============================================================================================-->
    <script src="~/login-form-v1/Login_v1/vendor/jquery/jquery-3.2.1.min.js"></script>
    <!--===============================================================================================-->
    <script src="~/login-form-v1/Login_v1/vendor/bootstrap/js/popper.js"></script>
    <script src="~/login-form-v1/Login_v1/vendor/bootstrap/js/bootstrap.min.js"></script>
    <!--===============================================================================================-->
    <script src="~/login-form-v1/Login_v1/vendor/select2/select2.min.js"></script>
    <!--===============================================================================================-->
    <script src="~/login-form-v1/Login_v1/vendor/tilt/tilt.jquery.min.js"></script>
    <script>
        $('.js-tilt').tilt({
            scale: 1.1
        })
    </script>
    <!--===============================================================================================-->
    <script src="~/login-form-v1/Login_v1/js/main.js"></script>

</body>
</html>
