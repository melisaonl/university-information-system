@model List<AkademikBilgiSistemi.Models.Tbl_Mesajlar>
@{
    ViewBag.Title = "GelenMesajlar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="content">

    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
            <button type="button" id="sidebarCollapse" class="btn btn-info">
                <i class="fas fa-align-left"></i>
            </button>
            <h3 style="position:absolute; right:90px; top:3px"> KAYSERİ ÜNİVERSİTESİ</h3>
            <img src="~/login-form-v1/Login_v1/images/uniLogo.png" style="height:60px; position:absolute; right:10px; top:2px" />
        </div>
    </nav>
    <div class="container-fluid">
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <div class="container-fluid">
                <h2>MESAJ KUTUSU</h2>
                <br />
                <div class="container">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Gönderen</th>
                                <th>Başlık</th>
                                <th>Mesaj</th>
                                <th>Gönderilme Tarihi</th>
                                <th></th>

                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Tbl_Ogrenciler.OgrAd @item.Tbl_Ogrenciler.OgrSoyad</td>
                                    <td>@item.Baslik</td>
                                    <td>@item.Icerik</td>
                                    <td>@Convert.ToDateTime(item.Tarih).ToShortDateString()</td>
                                    <td>

                                        <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#myModal-@item.MesajID">
                                                GÖRÜNTÜLE
                                            </button>
                                            <div class="modal" id="myModal-@item.MesajID">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">

                                                        <div class="modal-header">
                                                            <h4 class="modal-title">@item.Baslik</h4>
                                                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                                                        </div>

                                                        <div class="modal-body">
                                                            @item.Icerik
                                                        </div>

                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-danger" data-dismiss="modal">Kapat</button>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </nav>
    </div>
</div>



